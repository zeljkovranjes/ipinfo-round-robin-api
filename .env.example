# Required: comma-separated IPInfo API keys
IPINFO_KEYS=your_key_1,your_key_2,your_key_3

# Optional: server
PORT=8080
HOST=0.0.0.0

# Optional: key rotation
COOLDOWN_SECONDS=60
REQUEST_TIMEOUT_MS=5000
REDACT_KEYS=true

# Optional: cache
CACHE_TTL_SECONDS=300
CACHE_MAX_ENTRIES=10000

# Optional: logging
LOG_LEVEL=info
LOG_FORMAT=text

# Optional: override upstream (useful for testing)
IPINFO_BASE_URL=https://ipinfo.io
